# =============================================================================
# Harbor Registry — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before deployment.
# NEVER commit .env to version control.
# =============================================================================

# --- Harbor Domain ---
# The FQDN where Harbor will be accessible. Must match your DNS A-record.
# Used in all Traefik router Host() rules.
HARBOR_HOSTNAME=registry.yourdomain.com

# --- Traefik Integration ---
# Certificate resolver name configured in your Traefik static config.
TRAEFIK_CERT_RESOLVER=le

# --- Harbor Admin ---
# Initial admin password. Change immediately after first login via the UI.
HARBOR_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# --- Database ---
# PostgreSQL password for Harbor's internal database.
HARBOR_DB_PASSWORD=CHANGE_ME_ANOTHER_STRONG_PASSWORD

# --- Secret Key ---
# 16-character key used for encrypting credentials in the database.
# Generate with: openssl rand -hex 8
HARBOR_SECRET_KEY=CHANGE_ME_16CHARS

# --- Core Secret ---
# Shared secret between core and other components.
# Generate with: openssl rand -hex 16
CORE_SECRET=CHANGE_ME_32HEX_CHARS

# --- Job Service Secret ---
# Shared secret between core and jobservice.
# Generate with: openssl rand -hex 16
JOBSERVICE_SECRET=CHANGE_ME_32HEX_CHARS

# --- Registry Credentials ---
# Internal authentication between core and registry.
REGISTRY_HTTP_SECRET=CHANGE_ME_REGISTRY_SECRET
REGISTRY_CREDENTIAL_USERNAME=harbor_registry_user
REGISTRY_CREDENTIAL_PASSWORD=CHANGE_ME_REGISTRY_CRED_PASSWORD

# --- CSRF Key ---
# 32-character key for CSRF token generation.
# Generate with: openssl rand -base64 32
CSRF_KEY=CHANGE_ME_32CHAR_CSRF_KEY_BASE64
